---
import type { MemorialPhoto } from '../types/memorial';

interface Props {
	photos: MemorialPhoto[];
}

const { photos } = Astro.props;
---

{
	photos.length > 0 && (
		<section class="gallery-section" aria-labelledby="gallery-heading">
			<h2 class="section-heading" id="gallery-heading" data-testid="gallery-heading">
				Photos
			</h2>
			<ul class="gallery-grid">
				{photos.map((photo) => (
					<li class="gallery-item">
						<figure>
							<img
								src={photo.src}
								alt={photo.alt}
								loading="lazy"
								decoding="async"
								width="800"
								height="600"
								data-testid={`gallery-photo-${photo.id}`}
							/>
							{photo.caption && <figcaption>{photo.caption}</figcaption>}
						</figure>
					</li>
				))}
			</ul>
		</section>
	)
}
